{
  "cli": {
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview"
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "GRADLE_OPTS": "-Xmx4g -XX:MaxMetaspaceSize=512m"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6761982403"
      },
      "android": {
        "track": "internal"
      }
    }
  }
}
