{
  "expo": {
    "name": "ScanAlarm",
    "slug": "qr-alarm-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#F5F0EB"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yuasano.qralarm",
      "locales": {
        "ja": "./locales/ja.json",
        "en": "./locales/en.json",
        "ko": "./locales/ko.json",
        "es": "./locales/es.json"
      },
      "infoPlist": {
        "CFBundleDevelopmentRegion": "ja",
        "CFBundleLocalizations": [
          "ja",
          "en",
          "ko",
          "es"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F5F0EB"
      },
      "package": "com.yuasano.qralarm",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "com.google.android.gms.permission.AD_ID"
      ]
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/69f046ad-ed1b-43f0-9f07-ee113e81965e"
    },
    "scheme": "qralarm",
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "QRコード・バーコードをスキャンしてアラームを解除するためにカメラへのアクセスが必要です"
        }
      ],
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ],
      "expo-font",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-8032919792244446~8021236108",
          "iosAppId": "ca-app-pub-8032919792244446~4974167290"
        }
      ],
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "広告のパーソナライズのためにトラッキングを許可してください"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          },
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24,
            "kotlinVersion": "1.9.25"
          }
        }
      ],
      "expo-localization"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "69f046ad-ed1b-43f0-9f07-ee113e81965e"
      }
    },
    "owner": "ukdayoharry"
  }
}
