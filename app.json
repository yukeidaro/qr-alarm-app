{
  "expo": {
    "name": "ScanAlarm",
    "slug": "qr-alarm-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#F5F0EB"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yuasano.qralarm",
      "buildNumber": "36",
      "locales": {
        "ja": "./locales/ja.json",
        "en": "./locales/en.json",
        "ko": "./locales/ko.json",
        "es": "./locales/es.json"
      },
      "infoPlist": {
        "CFBundleDevelopmentRegion": "ja",
        "CFBundleLocalizations": [
          "ja",
          "en",
          "ko",
          "es"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "audio",
          "remote-notification"
        ],
        "NSCameraUsageDescription": "Camera is required to scan QR codes and barcodes to dismiss alarms."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F5F0EB"
      },
      "package": "com.yuasano.qralarm",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "com.google.android.gms.permission.AD_ID",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.USE_EXACT_ALARM",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK",
        "android.permission.USE_FULL_SCREEN_INTENT"
      ]
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/48e439db-6d50-426a-919f-da2371a46751"
    },
    "scheme": "qralarm",
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "QRコード・バーコードをスキャンしてアラームを解除するためにカメラへのアクセスが必要です"
        }
      ],
      [
        "expo-notifications",
        {
          "sounds": [
            "./assets/sounds/gentle.wav"
          ]
        }
      ],
      "expo-font",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-8032919792244446~8021236108",
          "iosAppId": "ca-app-pub-8032919792244446~4974167290"
        }
      ],
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "広告のパーソナライズのためにトラッキングを許可してください"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          },
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24,
            "kotlinVersion": "2.1.20"
          }
        }
      ],
      "expo-localization"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "48e439db-6d50-426a-919f-da2371a46751"
      }
    },
    "owner": "yuworks-studio"
  }
}
